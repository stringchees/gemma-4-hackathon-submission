# Copy this file to .env to enable live providers.

GEMMA_PROVIDER=ollama
GEMMA_MODEL=gemma4:e2b
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Create an ElevenLabs account/API key for live earpiece speech capture and playback.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
# Free-plan-compatible default voice tested for API playback.
ELEVENLABS_VOICE_ID=hpp4J3VqNfWAUOO0d1Us

CLINIC_SYNC_ENABLED=false
PORT=3000
HOST=127.0.0.1
